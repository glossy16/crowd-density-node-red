    {
        "id": "07d48e50d9fe0ba1",
        "type": "function",
        "z": "111c29150b248e1f",
        "name": "function 2",
        "func": "// Simulate passive infrared motion detection\n// Models normal vs spike activity (stampede precursor)\nconst baseMotion = Math.random();\nconst spikeEvent = Math.random() < 0.05; // 5% chance of a spike\nconst motionLevel = spikeEvent ? Math.min(1, baseMotion + 0.6) : baseMotion;\nconst triggered = motionLevel > 0.4;\n\nmsg.payload = {\n    sensor: \"pir\",\n    motion_level: +motionLevel.toFixed(3),\n    triggered: triggered,\n    spike_detected: spikeEvent,\n    zone: \"Gate-A\",\n    timestamp: new Date().toISOString()\n};\nmsg.topic = \"crowd/pir\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
