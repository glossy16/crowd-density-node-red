    {
        "id": "3cd01911dfab4269",
        "type": "function",
        "z": "111c29150b248e1f",
        "name": "function 3",
        "func": "// Simulate WiFi probe requests + BT advertisement scanning\n// Device count is a proxy for people count\nconst timeOfDay = new Date().getHours();\nconst peakHour = (timeOfDay >= 9 && timeOfDay <= 18);\nconst baseDevices = peakHour ? 45 : 12;\nconst deviceCount = Math.round(baseDevices + (Math.random() * 30) - 10);\nconst uniqueDevices = Math.round(deviceCount * 0.75); // ~75% unique\n\nmsg.payload = {\n    sensor: \"wifi_bt\",\n    total_devices: Math.max(0, deviceCount),\n    unique_devices: Math.max(0, uniqueDevices),\n    zone: \"Gate-A\",\n    rssi_avg: +(-(Math.random() * 40 + 50)).toFixed(1), // -50 to -90 dBm\n    timestamp: new Date().toISOString()\n};\nmsg.topic = \"crowd/wifi\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
