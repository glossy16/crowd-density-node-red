    {
        "id": "378a7bf60bfa5623",
        "type": "function",
        "z": "111c29150b248e1f",
        "name": "function 1",
        "func": "// Simulating HC-SR04 ultrasonic distance readings\n// Closer distance = more people, higher density\nconst zoneArea = 10; // square metres\nconst distance = Math.random() * 400 + 20; // 20–420 cm\nconst peopleEstimate = Math.max(0, Math.round((420 - distance) / 40));\nconst density = +(peopleEstimate / zoneArea).toFixed(2);\n\nmsg.payload = {\n    sensor: \"ultrasonic\",\n    distance_cm: +distance.toFixed(1),\n    people_estimate: peopleEstimate,\n    density_per_sqm: density,\n    zone: \"Gate-A\",\n    timestamp: new Date().toISOString()\n};\nmsg.topic = \"crowd/ultrasonic\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 300,
        "y": 200,
