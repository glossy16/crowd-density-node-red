    {
        "id": "fde3aa5a250af0e2",
        "type": "function",
        "z": "111c29150b248e1f",
        "name": "Risk Classifier",
        "func": "// 🔒 Safe extraction (no crash even if missing)\nconst state = msg.payload.state || {};\nconst ultrasonic = state.ultrasonic || {};\nconst pir = state.pir || {};\nconst wifi = state.wifi || {};\n\n// 🧠 Fallbacks (VERY IMPORTANT)\nconst density = ultrasonic.density ?? Math.random() * 3;\nconst motion = pir.motion_level ?? Math.random();\nconst spike = pir.spike ?? false;\nconst devices = wifi.unique_devices ?? Math.floor(Math.random() * 50);\n\n// 🎯 Weighted scoring system (0–100)\n\n// ❌ ORIGINAL LINE (commented)\n// let score = Math.random() > 0.7 ? 90 : 20;\n\n// ✅ NEW: calculate score normally first\nlet score = 0;\n\n// Ultrasonic (0–40)\nscore += Math.min(40, density * 11.4);\n\n// PIR (0–35)\nscore += motion * 25;\nif (spike) score += 10;\n\n// WiFi (0–25)\nscore += Math.min(25, (devices / 50) * 25);\n\n// ✅ NEW: AFTER calculation, randomly force CRITICAL sometimes\nif (Math.random() > 0.7) {\n    score = 90;  // force CRITICAL occasionally\n}\n\nscore = Math.min(100, Math.round(score));\n\n// 🧪 DEBUG (optional, remove later)\nnode.warn(\"Score = \" + score);\n\n// 🚦 Risk classification\nlet risk, color, action;\n\nif (score < 30) {\n    risk = \"LOW\";       \n    color = \"#2e7d32\"; \n    action = \"Normal monitoring\";\n} else if (score < 55) {\n    risk = \"MEDIUM\";    \n    color = \"#f57f17\"; \n    action = \"Increase vigilance\";\n} else if (score < 75) {\n    risk = \"HIGH\";      \n    color = \"#e65100\"; \n    action = \"Deploy staff to zone\";\n} else {\n    risk = \"CRITICAL\";  \n    color = \"#b71c1c\"; \n    action = \"Initiate evacuation protocol\";\n}\n\n// 📦 Final payload\nmsg.payload = {\n    risk_level: risk,\n    risk_score: score,\n    color: color,\n    recommended_action: action,\n\n    components: {\n        density: density,\n        motion: motion,\n        device_count: devices\n    },\n\n    zone: \"Gate-A\",\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1080,
        "y": 300,
        "wires": [
            []
        ]
    },
