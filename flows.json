    {
        "id": "03b182df2e5df68e",
        "type": "function",
        "z": "111c29150b248e1f",
        "name": "Sensor Fusion Engine",
        "func": "msg.payload.components = {\n    density: Math.floor(Math.random()*100),\n    motion: Math.random().toFixed(2),\n    device_count: Math.floor(Math.random()*50)\n};\nreturn msg;",
